{
  "name": "asra-lighthouse-monitor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lighthouse:mobile": "lighthouse https://www.asrapirlanta.com --preset=perf --chrome-flags=\"--headless --no-sandbox --disable-gpu --disable-dev-shm-usage\" --output=json --output=html --output-path=reports/mobile",

    "lighthouse:desktop": "lighthouse https://www.asrapirlanta.com --preset=desktop --chrome-flags=\"--headless --no-sandbox --disable-gpu --disable-dev-shm-usage\" --output=json --output=html --output-path=reports/desktop"
  },
  "devDependencies": {
    "lighthouse": "^12.8.2"
  }

  "scripts": {
  "lighthouse:mobile": "...",
  "lighthouse:desktop": "...",
  "history": "node scripts/history.js"
}
}


